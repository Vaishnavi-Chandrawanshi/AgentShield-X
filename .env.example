# FastAPI Gateway Core Configuration
PROJECT_NAME="AgentShield-X"
API_V1_STR="/api/v1"

# Database Connection URL (PostgreSQL with pgvector for production)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agentshield"

# JWT Sign Signature secret key (Change this to a strong random hash in production!)
SECRET_KEY="super-secret-key-for-development-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AES-256 GCM Encryption key for DB payload logging (Must be exactly 32 bytes/characters!)
ENCRYPTION_KEY="32bytessecretkeymustbe32charslong!"

# Administrative Credentials (Hardened to env variables)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="secure_production_password_change_me"

# AI Agent Framework Credentials
GEMINI_API_KEY="your-gemini-api-key-here"
